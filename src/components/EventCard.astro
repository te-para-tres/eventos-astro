---
interface Props {
  title: string;
  category: string;
  date: string;
  location: string;
  image: string;
  availability: string;
  availabilityColor: "emerald" | "amber";
}

const {
  title,
  category,
  date,
  location,
  image,
  availability,
  availabilityColor,
} = Astro.props;
---

<div
  class="bg-bg-alt border border-border-custom rounded-xl overflow-hidden flex flex-col transition-all duration-300 ease-in-out hover:shadow-xl hover:-translate-y-1 group"
>
  <div class="relative h-52 overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-110"
    />
    <div class="absolute top-4 left-4 flex items-center gap-2">
  <div class="px-3 py-1.5 rounded text-[0.625rem] font-bold uppercase tracking-widest shadow-md bg-primary text-white">
    {category}
  </div>

  <div
    class={`px-3 py-1.5 rounded text-[0.625rem] font-bold uppercase tracking-widest shadow-md text-white ${
      availabilityColor === "emerald"
        ? "bg-accent-emerald"
        : "bg-accent-amber"
    }`}
  >
    {availability}
  </div>
</div>
  </div>
  <div class="p-6 flex flex-col grow">
    <h3
      class="text-xl font-bold text-text-main leading-tight mb-4 transition-colors duration-200 group-hover:text-primary"
    >
      {title}
    </h3>
    <div class="mt-auto flex flex-col gap-3">
      <div class="flex items-center gap-3 text-sm text-text-muted">
        <span class="material-symbols-outlined text-xl text-primary">
          schedule
        </span>
        <span>{date}</span>
      </div>
      <div class="flex items-center gap-3 text-sm text-text-muted">
        <span class="material-symbols-outlined text-xl text-primary">
          location_on
        </span>
        <span>{location}</span>
      </div>
    </div>
    <button
      class="mt-6 w-full p-2.5 bg-transparent border-2 border-primary text-primary rounded-lg text-sm font-bold transition-all duration-200 hover:bg-primary hover:text-white hover:cursor-pointer"
    >
      Ver Detalles
    </button>
  </div>
</div>
