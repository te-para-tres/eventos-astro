---
import { Home, CalendarDays, Building2, Mail } from "lucide-react";

const links = [
  { label: "Inicio", href: "/", Icon: Home },
  { label: "Eventos", href: "/eventos", Icon: CalendarDays },
  { label: "Departamentos", href: "/departamentos", Icon: Building2 },
  { label: "Contacto", href: "#contacto", Icon: Mail },
];
const palabras = ["Eventues", "Eventues", "Eventues", "Eventues"];
---

<footer
  id="contacto"
  class="rounded-2xl bg-primary text-white overflow-hidden"
>
  <p class="text-center text-white/80 text-sm pt-10 px-6">
    © 2026 UES Eventos. Todos los derechos reservados.
  </p>

  <div
    class="relative w-full overflow-hidden select-none pointer-events-none my-6"
    aria-hidden="true"
  >
    <div class="flex w-max marquee-track">
      {
        [...palabras, ...palabras].map((palabra) => (
          <span
            class="mx-8 text-[18vw] md:text-[12vw] font-black leading-none text-white/15"
          >
            {palabra}
          </span>
        ))
      }
    </div>
  </div>

  <nav
    class="grid grid-cols-2 md:grid-cols-4 border-t border-white/20"
    aria-label="Enlaces del pie de página"
  >
    {
      links.map(({ label, href, Icon }) => (
        <a
          href={href}
          class="group flex items-center justify-center border-r border-white/20 last:border-r-0 px-3 py-5 text-white transition-colors duration-300 hover:bg-white hover:text-primary focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-white"
        >
          <Icon className="w-5 h-5 shrink-0" aria-hidden="true" />
          <span class="max-w-0 -translate-x-2 overflow-hidden whitespace-nowrap text-sm font-medium opacity-0 transition-all duration-300 group-hover:ml-2 group-hover:max-w-[140px] group-hover:translate-x-0 group-hover:opacity-100">
            {label}
          </span>
        </a>
      ))
    }
  </nav>

  <style>
    @keyframes footer-marquee {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-50%);
      }
    }
    .marquee-track {
      animation: footer-marquee 30s linear infinite;
      will-change: transform;
    }
    @media (prefers-reduced-motion: reduce) {
      .marquee-track {
        animation: none;
      }
    }
  </style>
</footer>
