---
import { Mail, School, Share2 } from "lucide-react";
---

<footer class="w-full mt-24 bg-bg-alt border-t border-border-custom pt-16 pb-8">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-16 mb-16">
      <div class="lg:col-span-2">
        <div class="flex items-center gap-3 mb-6">
          <div
            class="bg-primary text-white p-1.5 rounded flex items-center justify-center"
          >
            <School className="w-6 h-6" aria-hidden="true" />
          </div>
          <span class="text-xl font-bold text-primary">UES</span>
        </div>
        <p class="text-sm text-text-muted leading-relaxed max-w-xs">
          La plataforma oficial de descubrimiento de eventos para nuestra
          comunidad de la Universidad Estatal de Sonora.
        </p>
      </div>

      <div class="flex flex-col gap-6">
        <h4 class="text-xs font-bold uppercase tracking-widest text-text-main">
          Universidad
        </h4>
        <ul class="list-none p-0 m-0 flex flex-col gap-3">
          <li>
            <a
              href="#"
              class="text-sm text-text-muted no-underline transition-colors duration-200 hover:text-primary"
            >
              Sitio Web Principal
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-sm text-text-muted no-underline transition-colors duration-200 hover:text-primary"
            >
              Mapa del Campus
            </a>
          </li>
          <li>
            <a
              href="https://escolares.ues.mx/login.aspx" target="_blank"
              class="text-sm text-text-muted no-underline transition-colors duration-200 hover:text-primary"
            >
              Portal de Alumnos
            </a>
          </li>
        </ul>
      </div>

      <div class="flex flex-col gap-6">
        <h4 class="text-xs font-bold uppercase tracking-widest text-text-main">
          Legal
        </h4>
        <ul class="list-none p-0 m-0 flex flex-col gap-3">
          <li>
            <a
              href="#"
              class="text-sm text-text-muted no-underline transition-colors duration-200 hover:text-primary"
            >
              Aviso de Privacidad
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-sm text-text-muted no-underline transition-colors duration-200 hover:text-primary"
            >
              Términos de Servicio
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-sm text-text-muted no-underline transition-colors duration-200 hover:text-primary"
            >
              Accesibilidad
            </a>
          </li>
        </ul>
      </div>

      <div class="flex flex-col gap-6">
        <h4 class="text-xs font-bold uppercase tracking-widest text-text-main">
          Soporte
        </h4>
        <ul class="list-none p-0 m-0 flex flex-col gap-3">
          <li>
            <a
              href="#"
              class="text-sm text-text-muted no-underline transition-colors duration-200 hover:text-primary"
            >
              Centro de Ayuda
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-sm text-text-muted no-underline transition-colors duration-200 hover:text-primary"
            >
              Contacto Académico
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-sm text-text-muted no-underline transition-colors duration-200 hover:text-primary"
            >
              Soporte Técnico
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="pt-8 border-t border-primary flex flex-col md:flex-row justify-between items-center gap-8"
    >
      <p class="text-xs text-text-muted font-medium">
        © 2026 Universidad Estatal de Sonora - Tablero de Eventos. Todos los
        derechos reservados.
      </p>
      <div class="flex gap-6">
        <a
          href="https://www.facebook.com"
          target="_blank"
          class="text-primary hover:text-primary-hover transition-colors duration-200"
        >
          <i class="fa-brands fa-facebook-f text-xl"></i>
        </a>

        <a
          href="mailto:correo@ejemplo.com"
          class="text-primary hover:text-primary-hover transition-colors duration-200"
        >
          <Mail className="w-5 h-5" aria-hidden="true" />
        </a>

        <a
          href="#"
          class="text-primary hover:text-primary-hover transition-colors duration-200"
        >
          <Share2 className="w-5 h-5" aria-hidden="true" />
        </a>
      </div>
    </div>
  </div>
</footer>
