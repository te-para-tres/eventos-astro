---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div
  class="h-[3px] w-full bg-[linear-gradient(90deg,var(--color-primary)_0%,var(--color-primary-hover)_35%,#c4445f_50%,var(--color-primary-hover)_65%,var(--color-primary)_100%)] bg-[size:250%_auto] animate-[shimmer_5s_linear_infinite]"
>
</div>

<header
  class="sticky top-0 z-50 bg-white/88 backdrop-blur-2xl border-b border-border-custom"
>
  <div
    class="max-w-7xl w-full mx-auto px-6 h-[66px] flex justify-between items-center"
  >
    <div class="flex items-center gap-5">
      <a href="/" class="group flex items-center gap-3 no-underline">
        <div
          class="bg-primary rounded-lg p-[0.42rem] flex items-center justify-center text-white transition-all duration-[180ms] group-hover:bg-primary-hover group-hover:shadow-[0_4px_12px_rgba(123,22,62,0.28)]"
        >
          <span class="material-icons" style="font-size: 1.15rem;">school</span>
        </div>
        <div class="flex flex-col">
          <span
            class="text-[1.28rem] font-black tracking-tight text-primary leading-none"
          >
            UES
          </span>
          <span
            class="text-[8.5px] font-semibold text-text-muted uppercase tracking-[0.13em] leading-none mt-[3px]"
          >
            Universidad Estatal <br /> de Sonora
          </span>
        </div>
      </a>

      {
        title && (
          <div class="hidden md:flex items-center pl-5 border-l border-border-custom">
            <h1 class="text-[0.88rem] font-medium text-text-muted">{title}</h1>
          </div>
        )
      }
    </div>

    <nav class="flex items-center gap-1">
      <a
        href="/soporte"
        class="relative flex items-center gap-1.5 px-3 py-[0.45rem] text-[0.82rem] font-medium text-text-muted transition-colors duration-200 hover:text-text-main after:content-[''] after:absolute after:bottom-0 after:left-1/2 after:w-0 after:h-[1.5px] after:bg-primary after:rounded-sm after:[transition:width_0.22s_ease,left_0.22s_ease] hover:after:w-full hover:after:left-0"
      >
        <i class="fa-regular fa-circle-question" style="font-size: 0.8rem;"></i>
        <span>Soporte</span>
      </a>

      <span class="w-px h-4 bg-border-custom mx-1.5 block"></span>

      <a
        href="/iniciar-sesion"
        class="flex items-center gap-2 bg-primary px-4 py-[0.48rem] rounded-lg text-white text-[0.82rem] font-semibold transition-all duration-200 hover:bg-primary-hover hover:shadow-[0_4px_14px_rgba(123,22,62,0.3)] hover:-translate-y-px active:translate-y-0 active:shadow-none"
      >
        <i
          class="fa-solid fa-arrow-right-to-bracket"
          style="font-size: 0.78rem;"></i>
        <span>Iniciar sesión</span>
      </a>
    </nav>
  </div>
</header>
