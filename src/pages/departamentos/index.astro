---
import Layout from "@/layouts/Layout.astro";
import Breadcrumbs from "@/components/Breadcrumbs";
import type { Carrera } from "@/models/Carrera.model";
import { getCarreras } from "@/services/carreras";
import { Card } from "@/components/ui/card";
import { Building2 } from "lucide-react";

export const prerender = false;

const carreras = await getCarreras({
  ordenar: "nombre-asc",
});
---

<Layout
  title="Departamentos"
  description="Explora los departamentos y unidades académicas de la Universidad Estatal de Sonora y sus eventos."
>
  <div class="max-w-7xl mx-auto px-6 py-16">
    <Breadcrumbs
      items={[{ label: "Inicio", href: "/" }, { label: "Departamentos" }]}
      className="mb-6"
    />
    <h1 class="text-4xl font-extrabold mb-10">Departamentos</h1>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        carreras.map((c: Carrera) => (
          <a href={`/departamentos/${c.id}`} class="group block">
            <Card className="p-6 gap-0 border ring-0 shadow-none hover:shadow-lg transition cursor-pointer">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 bg-primary text-white rounded-full flex items-center justify-center">
                  <Building2 className="w-4 h-4" aria-hidden="true" />
                </div>
                <div>
                  <h2 class="font-bold group-hover:text-primary">
                    {c.nombre ?? "Sin nombre"}
                  </h2>
                  <p class="text-xs text-gray-500">{c.tipo ?? "—"}</p>
                </div>
              </div>
              <p class="text-sm text-gray-600">{c.descripcion ?? ""}</p>
            </Card>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
