---
import Layout from "@/layouts/Layout.astro";
import { Carrera } from "@/models/Carrera.model";
import { getCarreras } from "@/services/carreras";
import dayjs from "dayjs";
import "dayjs/locale/es";

export const prerender = false;
const { id } = Astro.params;

const carrera = await getCarreras({
  id: id,
  expand: Carrera.EXPAND.DEFAULT,
});

const carrers = carrera?.[0];
const eventos = Array.isArray(carrers?.eventos) ? carrers.eventos : [];
const unidad = carrers?.unidadAcademica;
---

<Layout
  title={carrers?.nombre ?? "Departamento"}
  description={carrers?.descripcion ?? "Departamento de la Universidad Estatal de Sonora."}
>
  <main class="px-3 sm:px-4 md:px-6 lg:px-8 py-6 max-w-7xl mx-auto">
    <nav class="flex items-center gap-2 text-xs sm:text-sm text-gray-400 mb-6">
      <a
        href="/departamentos"
        class="hover:text-primary cursor-pointer transition"
      >
        Departamentos
      </a>
      <i class="fa-solid fa-chevron-right text-[10px]"></i>
      <span class="text-gray-700 font-medium truncate">{carrers.nombre}</span>
    </nav>

    <div class="flex flex-col xl:grid xl:grid-cols-12 gap-6 lg:gap-8">
      <div class="xl:col-span-8 space-y-6">
        <div class="flex items-start gap-4">
          <div
            class="w-14 h-14 sm:w-16 sm:h-16 bg-primary rounded-2xl flex items-center justify-center text-white shrink-0 shadow-md"
          >
            <i class="fa-solid fa-building text-xl sm:text-2xl"></i>
          </div>
          <div>
            <p class="text-xs text-gray-400 uppercase tracking-widest mb-1">
              {carrers.tipo ?? "—"}
            </p>
            <h1
              class="text-xl sm:text-2xl md:text-3xl font-extrabold text-gray-900 leading-tight"
            >
              {carrers.nombre}
            </h1>
          </div>
        </div>

        {
          carrers.descripcion && (
            <div>
              <h2 class="font-bold text-base sm:text-lg text-gray-800 mb-2">
                DESCRIPCIÓN
              </h2>
              <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
                {carrers.descripcion}
              </p>
            </div>
          )
        }

        {
          eventos?.length > 0 && (
            <div>
              <h2 class="font-bold text-base sm:text-lg text-gray-800 mb-3">
                PROGRAMAS ACADÉMICOS
              </h2>
              <div class="flex flex-col gap-2">
                {eventos?.map((ev) => (
                  <a
                    href={`/eventos/${ev.id}`}
                    class="flex items-center gap-3 p-3 sm:p-4 rounded-lg border bg-gray-50 hover:shadow-sm transition cursor-pointer group"
                  >
                    <div class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                      <i class="fa-solid fa-graduation-cap text-primary text-sm" />
                    </div>
                    <span class="text-sm sm:text-base font-medium text-gray-700 group-hover:text-primary transition">
                      {ev.nombre ?? "Sin nombre"}
                    </span>
                    <i class="fa-solid fa-chevron-right text-gray-300 text-xs ml-auto group-hover:text-primary transition" />
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </div>

      <div class="xl:col-span-4 space-y-5">
        <div
          class="p-5 border-t-4 border-primary rounded-xl shadow-md space-y-3"
        >
          <p class="text-xs text-gray-400 uppercase tracking-widest">
            Contacto
          </p>
          <div class="space-y-2 text-sm text-gray-600">
            <p class="flex items-center gap-2">
              <i class="fa-regular fa-envelope text-primary w-4"></i>
              {unidad?.correo ?? `depto.${carrers.id}@ues.edu.sv`}
            </p>
            <p class="flex items-center gap-2">
              <i class="fa-solid fa-phone text-primary w-4"></i>
              {unidad?.telefono ?? "—"}
            </p>
            <p class="flex items-center gap-2">
              <i class="fa-solid fa-location-dot text-primary w-4"></i>
              {unidad?.nombre ?? "UES"}
            </p>
          </div>
          <button
            class="w-full bg-black/75 text-white py-2.5 rounded-lg font-semibold hover:bg-primary transition flex items-center justify-center gap-2 text-sm cursor-pointer mt-2"
          >
            Enviar mensaje
            <i class="fa-solid fa-paper-plane"></i>
          </button>
        </div>

        {
          eventos?.length > 0 && (
            <div class="p-4 sm:p-5 rounded-xl border shadow-sm space-y-4">
              <p class="text-xs text-gray-400 uppercase tracking-widest">
                Próximos eventos
              </p>
              <div class="flex flex-col gap-3">
                {eventos?.map((ev) => (
                  <a
                    href="/eventos"
                    class="flex items-center gap-3 p-2.5 rounded-lg border hover:shadow-sm transition cursor-pointer group"
                  >
                    <div class="w-10 h-10 bg-gray-100 rounded-lg flex items-center justify-center shrink-0">
                      <i class="fa-solid fa-calendar-days text-gray-400" />
                    </div>
                    <div class="min-w-0">
                      <p class="text-xs text-gray-400">
                        {ev.fechaInicio
                          ? dayjs(ev.fechaInicio)
                              .locale("es")
                              .format("D MMM YYYY")
                          : "—"}
                      </p>
                      <p class="text-sm font-medium leading-snug truncate group-hover:text-primary transition">
                        {ev.nombre ?? "Sin nombre"}
                      </p>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )
        }

        <a
          href="/departamentos"
          class="w-full border py-2.5 rounded-lg text-gray-600 font-medium hover:bg-gray-50 transition text-sm flex items-center justify-center gap-2 cursor-pointer"
        >
          <i class="fa-solid fa-arrow-left"></i>
          Ver todos los departamentos
        </a>
      </div>
    </div>
  </main>
</Layout>
