---
import Layout from "@/layouts/Layout.astro";
import Breadcrumbs from "@/components/Breadcrumbs";
import { Carrera } from "@/models/Carrera.model";
import { getCarreras } from "@/services/carreras";
import { Card } from "@/components/ui/card";
import {
  ArrowLeft,
  Building2,
  CalendarDays,
  ChevronRight,
  Mail,
  MapPin,
  Phone,
  Send,
  Users,
} from "lucide-react";
import dayjs from "dayjs";
import "dayjs/locale/es";
import { URL_RECURSOS } from "@/constants";

export const prerender = false;
const { id } = Astro.params;

const carrera = await getCarreras({
  id: id,
  expand: Carrera.EXPAND.DEFAULT,
});

const carrers = carrera?.[0];
const eventos = Array.isArray(carrers?.eventos) ? carrers.eventos : [];
const unidad = carrers?.unidadAcademica;

const telefonoWhatsapp = (unidad?.telefono ?? "").replace(/\D/g, "");
const mensajeWhatsapp = `Hola, me gustaría recibir más información sobre la carrera ${carrers?.nombre ?? ""}.`;
const whatsappUrl = telefonoWhatsapp
  ? `https://wa.me/+52${telefonoWhatsapp}?text=${encodeURIComponent(mensajeWhatsapp)}`
  : undefined;
---

<Layout
  title={carrers?.nombre ?? "Departamento"}
  description={carrers?.descripcion ??
    "Departamento de la Universidad Estatal de Sonora."}
>
  <main class="flex justify-center items-center w-full h-auto">
    <div class="w-full px-6 py-16 max-w-7xl mx-auto">
      <Breadcrumbs
        items={[
          { label: "Inicio", href: "/" },
          { label: "Departamentos", href: "/departamentos" },
          { label: carrers?.nombre ?? "Departamento" },
        ]}
        className="mb-6"
      />

      <div class="flex flex-col xl:grid xl:grid-cols-12 gap-6 lg:gap-8">
        <div class="xl:col-span-8 space-y-6">
          <div class="flex items-start gap-4">
            <div
              class="w-14 h-14 sm:w-16 sm:h-16 bg-primary rounded-lg flex items-center justify-center text-white shrink-0 shadow-md"
            >
              <Building2 className="w-6 h-6 sm:w-7 sm:h-7" aria-hidden="true" />
            </div>
            <div>
              <p class="text-xs text-gray-400 uppercase tracking-widest mb-1">
                {carrers?.tipo ?? "—"}
              </p>
              <h1
                class="text-xl sm:text-2xl md:text-3xl font-bold text-gray-900 leading-tight"
              >
                {carrers?.nombre}
              </h1>
            </div>
          </div>

          {
            carrers?.descripcion && (
              <div>
                <h2 class="font-bold text-base sm:text-lg text-gray-800 mb-2">
                  DESCRIPCIÓN
                </h2>
                <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
                  {carrers?.descripcion}
                </p>
              </div>
            )
          }

          {
            eventos?.length > 0 && (
              <div>
                <h2 class="font-bold text-base sm:text-lg text-gray-800 mb-3">
                  PROGRAMAS ACADÉMICOS
                </h2>
                <div class="flex flex-col gap-2">
                  {eventos?.map((ev) => (
                    <a
                      href={`/eventos/${ev.id}`}
                      class="flex gap-3 p-3 sm:p-4 rounded-lg border bg-gray-50 hover:border-primary hover:shadow-sm transition cursor-pointer group"
                    >
                      <img
                        src={`${URL_RECURSOS}/${ev?.imagenDestacada?.ruta}`}
                        alt={ev.nombre}
                        class="size-16 sm:size-20 object-cover rounded-lg shrink-0"
                      />
                      <div class="min-w-0 flex flex-col gap-1.5">
                        <div class="flex items-center justify-between gap-2">
                          <span class="text-base sm:text-lg font-semibold text-gray-900 group-hover:text-primary transition truncate">
                            {ev.nombre ?? "Sin nombre"}
                          </span>
                          <ChevronRight
                            className="w-4 h-4 text-gray-500 shrink-0 group-hover:text-primary transition"
                            aria-hidden="true"
                          />
                        </div>
                        <p class="flex items-center gap-1.5 text-sm text-gray-600">
                          <CalendarDays
                            className="w-4 h-4 shrink-0"
                            aria-hidden="true"
                          />
                          {ev?.fechaInicio
                            ? dayjs(ev?.fechaInicio).locale("es").format("D MMM")
                            : "—"}{" "}
                          -{" "}
                          {ev?.fechaFin
                            ? dayjs(ev?.fechaFin)
                                .locale("es")
                                .format("D MMM YYYY")
                            : "—"}
                        </p>
                        {ev?.descripcion && (
                          <p class="text-sm text-gray-700 leading-snug line-clamp-2">
                            {ev?.descripcion}
                          </p>
                        )}
                        <div class="flex items-center gap-1.5 text-sm text-gray-700">
                          <Users
                            className="w-4 h-4 shrink-0 text-primary"
                            aria-hidden="true"
                          />
                          <span>
                            Cupo: {ev?.capacidadMinima ?? 0} -{" "}
                            {ev?.capacidadMaxima ?? 0}
                          </span>
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        <div class="xl:col-span-4 space-y-5">
          <Card
            className="p-5 gap-3 border-t-4 border-primary ring-0 shadow-md"
          >
            <p class="text-xs text-primary font-medium uppercase tracking-widest">
              Contacto
            </p>
            <div class="space-y-2 text-sm text-gray-600">
              <p class="flex items-center gap-2">
                <Mail
                  className="text-primary w-4 h-4 shrink-0"
                  aria-hidden="true"
                />
                {unidad?.correo ?? `depto.${carrers?.id}@ues.edu.sv`}
              </p>
              <p class="flex items-center gap-2">
                <Phone
                  className="text-primary w-4 h-4 shrink-0"
                  aria-hidden="true"
                />
                {unidad?.telefono ?? "—"}
              </p>
              <p class="flex items-center gap-2">
                <MapPin
                  className="text-primary w-4 h-4 shrink-0"
                  aria-hidden="true"
                />
                {unidad?.nombre ?? "UES"}
              </p>
            </div>
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full inline-flex items-center justify-center gap-2 bg-primary text-white py-2.5 rounded-lg font-semibold hover:bg-rose-900 transition duration-300 text-sm cursor-pointer mt-2"
            >
              Enviar mensaje
              <Send className="w-4 h-4" aria-hidden="true" />
            </a>
          </Card>

          {
            eventos?.length > 0 && (
              <Card className="p-4 sm:p-5 gap-4 border ring-0 shadow-sm">
                <p class="text-xs text-primary font-medium uppercase tracking-widest">
                  Próximos eventos
                </p>
                <div class="flex flex-col gap-3">
                  {eventos?.map((ev) => (
                    <a
                      href={`/eventos/${ev?.id}`}
                      class="flex items-center gap-3 p-2.5 rounded-lg border hover:border-primary hover:shadow-sm transition cursor-pointer group"
                    >
                      <div class="rounded-lg flex items-center justify-center shrink-0">
                        <img
                          src={`${URL_RECURSOS}/${ev?.imagenDestacada?.ruta}`}
                          alt={ev?.nombre}
                          class="size-10 object-cover rounded"
                        />
                      </div>
                      <div class="min-w-0">
                        <p class="text-xs text-stone-500">
                          {ev?.fechaInicio
                            ? dayjs(ev?.fechaInicio).locale("es").format("D MMM")
                            : "—"}{" "}
                          -{" "}
                          {ev?.fechaFin
                            ? dayjs(ev?.fechaFin)
                                .locale("es")
                                .format("D MMM YYYY")
                            : "—"}
                        </p>
                        <p class="text-sm font-medium leading-snug truncate group-hover:text-primary transition">
                          {ev?.nombre ?? ""}
                        </p>
                      </div>
                    </a>
                  ))}
                </div>
              </Card>
            )
          }

          <a
            href="/departamentos"
            class="w-full border py-2.5 rounded-lg text-primary font-medium hover:bg-gray-50 transition text-sm flex items-center justify-center gap-2 cursor-pointer"
          >
            <ArrowLeft className="w-4 h-4" aria-hidden="true" />
            Ver todos los departamentos
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>
