---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Detalle del evento"
  description="Detalle de un evento de la Universidad Estatal de Sonora."
>
  <nav
    class="sticky top-0 z-50 bg-white dark:bg-[#1a1a1a] border-b-4 border-[#d4a017] shadow-md"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-20 items-center">
        <div class="flex items-center gap-4">
          <div class="h-14 flex items-center">
            <div class="bg-primary p-2 rounded-sm">
              <span class="material-icons text-white text-3xl" aria-hidden="true">school</span>
            </div>
          </div>
          <div class="flex flex-col leading-none">
            <span class="font-black text-2xl tracking-tighter text-primary"
              >UES</span
            >
            <span
              class="text-[10px] font-bold text-slate-500 uppercase tracking-widest"
              >Portal de Eventos</span
            >
          </div>
        </div>
        <div class="hidden md:flex items-center space-x-8">
          <a
            class="text-xs font-bold uppercase tracking-widest border-b-2 border-transparent hover:border-primary transition-all py-1"
            href="#">Inicio</a
          >
          <a
            class="text-xs font-bold uppercase tracking-widest border-b-2 border-transparent hover:border-primary transition-all py-1"
            href="#">Eventos</a
          >
          <a
            class="text-xs font-bold uppercase tracking-widest border-b-2 border-transparent hover:border-primary transition-all py-1"
            href="#">Organización</a
          >
        </div>
        <div class="flex items-center gap-4">
          <button
            aria-label="Notificaciones"
            class="p-2 text-primary hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors"
          >
            <span class="material-icons" aria-hidden="true">notifications</span>
          </button>
          <div
            class="h-10 w-10 rounded-full bg-slate-200 border-2 border-[#d4a017] overflow-hidden"
          >
            <img
              alt="Profile"
              class="w-full h-full object-cover"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuAt6qYsFwyumXPVgPN1OaoKvmKiFNb7oGaDjMjrv8AIshLqU4gUDfXPet3Pd6jUca443E_y8sCDz2qvYXH4z1tRTCjo5mIwrgILZR39khlFXp6ROCU62CewmLitKkO1vYdHKTD5ndyqQ-_5wEcqyKIiqHOTXszHi8URPo3jsb34WhQwi1U5Ld1ATzCw_rZyw82vUe4tuYBchZWyoV2bkoZ7RzqPxfxSosrt1tMTPcNLY1egwVrbjRkRi16smR4X2vIenpmZZg_yyw"
            />
          </div>
        </div>
      </div>
    </div>
  </nav>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <nav
      class="flex items-center text-xs font-bold uppercase tracking-wider text-slate-400 mb-8 gap-2"
    >
      <a class="hover:text-primary transition-colors" href="#"
        >Calendario de Eventos</a
      >
      <span class="material-icons text-xs" aria-hidden="true">chevron_right</span>
      <a class="hover:text-primary transition-colors" href="#"
        >Tecnología y Ciencia</a
      >
      <span class="material-icons text-xs" aria-hidden="true">chevron_right</span>
      <span class="text-primary">Simposio Anual de IA y Ética</span>
    </nav>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
      <div class="lg:col-span-8 space-y-10">
        <div
          class="relative aspect-video rounded-xl overflow-hidden shadow-2xl group"
        >
          <img
            alt="Event Hero"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuA3po3mEjlzZj0IPwjOdPw1tpZ1sBtulompnXeq8nHQ4pgvvIaZbXmXTB7zxkuLikWY3fozzcoqbXKD28Fgz4PDqzUHVq9Xr32JYox9d_63v_Z_YbsV6bnE662BrnS1OMmogOmmlc-L9I0yV56-QL1suGSlLloR3uS6Z_Z-1ToVNNCZWB_Nt-JDXiEEPhDypr8Jows6OQBi74xkv_zEIbEoUe9JjLeKo1Y_b68pu2Sg-oLFGb_RxCyhRGn5ee4xketXGOgC9WsiVw"
          />
          <div class="absolute top-6 left-6">
            <span
              class="bg-[#d4a017] text-primary text-[10px] font-black px-4 py-2 rounded-sm uppercase tracking-[0.2em] shadow-xl"
              >Evento Destacado</span
            >
          </div>
        </div>
        <div class="space-y-6">
          <h1
            class="text-4xl md:text-5xl font-black text-primary leading-tight"
          >
            Simposio Anual de IA y Ética: Navegando el Futuro de la Educación
            Superior
          </h1>
          <div
            class="flex flex-wrap gap-8 items-center text-slate-600 dark:text-slate-400"
          >
            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center"
              >
                <span class="material-icons text-primary" aria-hidden="true">calendar_today</span>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase text-slate-400">
                  Fecha
                </p>
                <p class="text-sm font-bold text-slate-800 dark:text-slate-200">
                  Viernes, 24 de Octubre, 2024
                </p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center"
              >
                <span class="material-icons text-primary" aria-hidden="true">schedule</span>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase text-slate-400">
                  Horario
                </p>
                <p class="text-sm font-bold text-slate-800 dark:text-slate-200">
                  9:00 AM — 4:30 PM (MST)
                </p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div
                class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center"
              >
                <span class="material-icons text-primary" aria-hidden="true">location_on</span>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase text-slate-400">
                  Ubicación
                </p>
                <p class="text-sm font-bold text-slate-800 dark:text-slate-200">
                  Centro de Innovación, Aula 402
                </p>
              </div>
            </div>
          </div>
        </div>
        <hr class="border-slate-200 dark:border-slate-800" />
        <div class="space-y-6">
          <h3 class="text-2xl font-black text-primary uppercase tracking-tight">
            Sobre este evento
          </h3>
          <div class="prose prose-slate dark:prose-invert max-w-none">
            <p
              class="text-lg leading-relaxed text-slate-700 dark:text-slate-300"
            >
              Únase a nosotros en nuestro simposio anual insignia donde cerramos
              la brecha entre la inteligencia artificial de vanguardia y la
              ética institucional. Este año, reuniremos a investigadores de
              clase mundial, responsables de políticas y líderes estudiantiles
              para discutir cómo los modelos de IA están remodelando el panorama
              de la integridad académica y el aprendizaje personalizado.
            </p>
            <p
              class="text-lg leading-relaxed text-slate-700 dark:text-slate-300"
            >
              El evento contará con conferencias magistrales de líderes de la
              industria, seguidas de sesiones interactivas y un almuerzo de
              networking en el atrio. Ya sea que seas estudiante de ciencias de
              la computación o un entusiasta de la filosofía, este simposio
              ofrece perspectivas vitales sobre las herramientas que definirán
              tu futura carrera profesional.
            </p>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4">
            <div
              class="p-6 bg-white dark:bg-slate-800/50 border-l-4 border-[#d4a017] shadow-sm"
            >
              <span class="material-icons text-primary mb-3 text-3xl" aria-hidden="true"
                >restaurant</span
              >
              <h4 class="font-black text-primary uppercase text-sm mb-2">
                Catering Incluido
              </h4>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Café por la mañana y almuerzo buffet tipo mediterráneo para
                todos los asistentes registrados.
              </p>
            </div>
            <div
              class="p-6 bg-white dark:bg-slate-800/50 border-l-4 border-[#d4a017] shadow-sm"
            >
              <span class="material-icons text-primary mb-3 text-3xl" aria-hidden="true"
                >badge</span
              >
              <h4 class="font-black text-primary uppercase text-sm mb-2">
                Constancia de Asistencia
              </h4>
              <p class="text-sm text-slate-600 dark:text-slate-400">
                Se emitirán certificados digitales a los participantes para sus
                portafolios profesionales.
              </p>
            </div>
          </div>
        </div>
        <div class="space-y-6">
          <h3 class="text-2xl font-black text-primary uppercase tracking-tight">
            Detalles de Ubicación
          </h3>
          <div
            class="rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800 h-80 relative group shadow-lg"
          >
            <div class="absolute inset-0">
              <img
                alt="Map View"
                class="w-full h-full object-cover"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuC6QEQGamEY-xCkLBsXDuJ_VS4qLRQUO5qM6nex6fyqDukkpP1hUkTC2JlnjCzwhXxpxdIkeYrqXW-hIu-OVTwixYIsolmaMVu0ZuC_AG3jvNGXeGDA9ufRdE_kOZv5O_VoBu-JD7Is_jqlEROdTrPFEzhmzrLhXopewNSbidvFon21Gho0eo2E4wklRor38VT1oBTSjiIXcnzhyy1KOWcE1HMP-kWlUV0lIZF9PdYAt1AKCmY8pJuoNJAewZ9l_jTlEEWJIaSXzA"
              />
              <div
                class="absolute inset-0 bg-gradient-to-t from-primary/40 to-transparent"
              >
              </div>
            </div>
            <div
              class="absolute bottom-6 left-6 bg-white dark:bg-slate-900 p-4 rounded-lg shadow-2xl flex items-center gap-4 border-b-4 border-[#d4a017]"
            >
              <div class="bg-primary p-2 rounded">
                <span class="material-icons text-white" aria-hidden="true">pin_drop</span>
              </div>
              <div>
                <p class="text-sm font-black text-primary">
                  Centro de Innovación
                </p>
                <p class="text-xs text-slate-500 font-medium">
                  Unidad Académica Hermosillo, UES
                </p>
              </div>
            </div>
            <button
              class="absolute top-6 right-6 bg-primary text-white px-6 py-3 rounded font-bold shadow-xl hover:bg-primary/90 transition-all flex items-center gap-2 uppercase text-xs tracking-widest"
            >
              <span class="material-icons text-sm" aria-hidden="true">directions</span>
              Cómo llegar
            </button>
          </div>
        </div>
        <div class="space-y-8">
          <h3 class="text-2xl font-black text-primary uppercase tracking-tight">
            Ponentes
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            <div
              class="flex items-center gap-5 p-4 bg-white dark:bg-slate-800/40 rounded-xl border border-slate-100 dark:border-slate-800"
            >
              <img
                alt="Speaker 1"
                class="w-20 h-20 rounded-full object-cover border-4 border-[#d4a017]"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuCdKxCTOQj2TzmuAxQBa2Y3F4X7zT99GjxIztjSGfFFJS346UE__qDGazs41alCyMHQLKrmq791U3jcygcgvWBv1o7DXzppSfsdxKFp7CtKe38leId4siWohdB1FGEdz591dN2ijS-NdLUgN854Q3Y3uXCBOLpwj2aItKXSZ5a2LyEinwb8wIX1fj5IMJKGfvoB975N2sn2uKrhNZE8RvJ6wTrxIp_8G2s_nniAis6XD59S6WAk0lfibI_kcj0Jzk91tyhnMblSiw"
              />
              <div>
                <h4 class="font-black text-primary">Dr. Marcus Chen</h4>
                <p
                  class="text-xs font-bold text-slate-500 uppercase tracking-wider"
                >
                  Director de Investigación en IA
                </p>
              </div>
            </div>
            <div
              class="flex items-center gap-5 p-4 bg-white dark:bg-slate-800/40 rounded-xl border border-slate-100 dark:border-slate-800"
            >
              <img
                alt="Speaker 2"
                class="w-20 h-20 rounded-full object-cover border-4 border-[#d4a017]"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuA8oO3k3BaOscx3vIIaXTJ9yNvuFP1GorqfM3xakuuznyX90GSwwqIzm1rZGK52BDVGF8mpCarOWUduT5WxeqqNk9D9kfp8HPfoZ7AztsmvCEeE5UPgHLYSnhdA-QpY67pfxJs_ZKhKKPRZXsVllnQZD2JjwctymYBQj34zthbQtQ9RNc4MFcJcsbVT7r1w7QQQuJzqWe5pFHQe8Uo1xPHcwLoclE0hDI1ZlAGZhiReD15M85lgwSxPE31Kp2zDCOIPDEEGx6OJRA"
              />
              <div>
                <h4 class="font-black text-primary">Sarah Jenkins</h4>
                <p
                  class="text-xs font-bold text-slate-500 uppercase tracking-wider"
                >
                  Presidenta del Comité de Ética
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="lg:col-span-4 space-y-8">
        <div class="sticky top-28 space-y-8">
          <div
            class="bg-white dark:bg-slate-900 border-t-8 border-primary rounded-xl shadow-2xl overflow-hidden"
          >
            <div class="p-8 space-y-8">
              <div class="space-y-3">
                <div class="flex justify-between items-end">
                  <span
                    class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400"
                    >Lugares Disponibles</span
                  >
                  <span class="text-xl font-black text-primary"
                    >158 <span class="text-sm text-slate-400 font-bold"
                      >/ 200</span
                    ></span
                  >
                </div>
                <div
                  class="w-full h-3 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden"
                >
                  <div
                    class="h-full bg-gradient-to-r from-primary to-[#d4a017] rounded-full"
                    style="width: 79%;"
                  >
                  </div>
                </div>
                <p
                  class="text-[10px] font-bold text-[#d4a017] flex items-center gap-1 uppercase tracking-wider"
                >
                  <span class="material-icons text-[14px]" aria-hidden="true">trending_up</span>
                  ¡Alta Demanda! 12 personas viendo ahora
                </p>
              </div>
              <div class="space-y-4">
                <button
                  class="w-full bg-primary hover:bg-primary/95 text-white font-black py-5 rounded shadow-xl shadow-primary/20 transition-all flex items-center justify-center gap-3 uppercase tracking-widest text-sm"
                >
                  Confirmar Asistencia
                  <span class="material-icons" aria-hidden="true">send</span>
                </button>
                <p
                  class="text-[10px] text-center text-slate-400 font-medium px-4"
                >
                  Al confirmar, usted acepta las políticas de eventos de la
                  Universidad Estatal de Sonora.
                </p>
              </div>
              <hr class="border-slate-100 dark:border-slate-800" />
              <div class="space-y-4">
                <button
                  class="w-full flex items-center gap-4 text-xs font-bold uppercase tracking-widest text-slate-600 dark:text-slate-400 hover:text-primary transition-colors group"
                >
                  <span
                    class="material-icons text-slate-300 group-hover:text-primary transition-colors" aria-hidden="true"
                    >calendar_add_on</span
                  >
                  Agregar al Calendario
                </button>
                <button
                  class="w-full flex items-center gap-4 text-xs font-bold uppercase tracking-widest text-slate-600 dark:text-slate-400 hover:text-primary transition-colors group"
                >
                  <span
                    class="material-icons text-slate-300 group-hover:text-primary transition-colors" aria-hidden="true"
                    >share</span
                  >
                  Compartir con amigos
                </button>
                <button
                  class="w-full flex items-center gap-4 text-xs font-bold uppercase tracking-widest text-slate-600 dark:text-slate-400 hover:text-primary transition-colors group"
                >
                  <span
                    class="material-icons text-slate-300 group-hover:text-primary transition-colors" aria-hidden="true"
                    >mail_outline</span
                  >
                  Contactar Organizador
                </button>
              </div>
            </div>
          </div>
          <div
            class="bg-primary/5 dark:bg-primary/10 border-2 border-primary/10 rounded-xl p-8 shadow-sm"
          >
            <h4
              class="text-[10px] font-black uppercase tracking-[0.2em] text-primary/60 mb-6"
            >
              Organizado por
            </h4>
            <div class="flex items-center gap-4 mb-6">
              <div
                class="w-14 h-14 bg-primary rounded-xl flex items-center justify-center shadow-lg"
              >
                <span class="material-symbols-outlined text-white text-3xl"
                  >hub</span
                >
              </div>
              <div>
                <h5
                  class="font-black text-slate-800 dark:text-white leading-tight"
                >
                  Departamento de IA
                </h5>
                <p class="text-xs font-bold text-primary">
                  División de Ingeniería
                </p>
              </div>
            </div>
            <button
              class="w-full bg-white dark:bg-slate-800 border-2 border-primary/20 py-3 rounded text-[10px] font-black uppercase tracking-widest text-primary hover:bg-primary hover:text-white transition-all"
            >
              Seguir Departamento
            </button>
          </div>
          <div class="space-y-4">
            <h4
              class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-400"
            >
              Eventos Relacionados
            </h4>
            <a
              class="group block bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 rounded-xl p-4 hover:shadow-xl transition-all border-l-4 border-[#d4a017]"
              href="#"
            >
              <div class="flex gap-4">
                <img
                  alt="Similar Event 1"
                  class="w-16 h-16 rounded object-cover shadow-md"
                  src="https://lh3.googleusercontent.com/aida-public/AB6AXuCdrNGx8PjVsE0pXGEacGoGEVFjZFle24PcR4qeGDhcaBrMTi1-pALLHSxN4g1V3t7sQmyHFtp3-jtelUw1ujeV3-n_y2NMErBmlUcInN6V2h1rGUP_IAEjpc6MStubGHMGzMmDs0J_uAUorDD05X_4_aneEBMsnTW1yH97wPA_WIgu97E_KjTeeAQ-HW8OhNkdnr36BcRz3cmY_4UTJQuN5kM_cXO0zfEypp6VtOkmvf86SgvE38hug1BDXgFsnpmXyukt3LcdXA"
                />
                <div class="flex-1">
                  <p class="text-[10px] text-primary font-black uppercase">
                    12 Nov
                  </p>
                  <h5
                    class="text-sm font-bold line-clamp-2 text-slate-800 dark:text-white group-hover:text-primary transition-colors"
                  >
                    Taller de Ética en Robótica
                  </h5>
                </div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
    <div
      class="fixed bottom-0 left-0 right-0 bg-white dark:bg-slate-900 border-t-4 border-[#d4a017] p-4 lg:hidden z-50 flex items-center justify-between shadow-[0_-10px_30px_rgba(0,0,0,0.1)]"
    >
      <div>
        <p
          class="text-[10px] font-black uppercase text-slate-400 tracking-wider"
        >
          Registro Abierto
        </p>
        <p class="text-lg font-black text-primary leading-tight">158 lugares</p>
      </div>
      <button
        class="bg-primary text-white px-10 py-4 rounded font-black uppercase tracking-widest text-xs shadow-lg"
        >Confirmar</button
      >
    </div>
  </main>
</Layout>
